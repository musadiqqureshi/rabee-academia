# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key for admin operations (provisioning admins/teachers, etc.).
# NEVER expose this to the browser. Used by future Edge Functions / server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (OpenRouter / NVIDIA NIM — OpenAI-compatible)
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-...
# Model for the DASHBOARD AI (Rabee's AI tutor, site assistant, quiz/assignment
# generation). Defaults to cohere/north-mini-code:free if unset.
AI_MODEL=
# Model for the Rabee's AI TOOLS (Paper Maker, Essay Grader, Lesson Plan, Notes,
# Planner, Quiz). Independent of AI_MODEL. Defaults to
# meta-llama/llama-3.3-70b-instruct:free if unset.
AI_TOOLS_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional Anthropic fallback (used only if AI_BASE_URL/AI_API_KEY are unset).
ANTHROPIC_API_KEY=

# AssanPay (Stage 2)
ASSANPAY_MERCHANT_ID=
ASSANPAY_API_KEY=
ASSANPAY_RETURN_URL=

# IBAN payment details shown to international students (Stage 2)
NEXT_PUBLIC_IBAN_NUMBER=
NEXT_PUBLIC_IBAN_BANK_NAME=
NEXT_PUBLIC_IBAN_ACCOUNT_TITLE=
